# ===== Обязательные переменные =====

# Токен Telegram-бота, выдаётся @BotFather.
TELEGRAM_BOT_TOKEN=

# Ключ OpenRouter, создаётся на https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ===== Необязательные переменные (показаны значения по умолчанию) =====

# Модель OpenRouter. Любой slug из https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-4o-mini

# Эндпоинт chat-completions. Менять обычно не нужно.
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions

# Атрибуция запросов в OpenRouter (необязательно, но рекомендуется).
OPENROUTER_REFERER=
OPENROUTER_TITLE=Bratok Bot

# Провайдеры OpenRouter, которые НЕ использовать (через запятую).
# По умолчанию пусто — используются все доступные провайдеры.
# Можно вписать Azure, чтобы избежать его фильтра контента (content_filter),
# НО только если в настройках приватности OpenRouter разрешены другие провайдеры,
# иначе получишь 404 "No endpoints available". См. https://openrouter.ai/settings/privacy
OPENROUTER_IGNORE_PROVIDERS=

# Необязательно: приоритетный порядок провайдеров, например: OpenAI,DeepInfra
OPENROUTER_PROVIDER_ORDER=

# «Температура» генерации: выше — живее и креативнее, ниже — суше и стабильнее.
# Разумный диапазон 0.0–1.2. По умолчанию 0.8.
OPENROUTER_TEMPERATURE=0.8

# Прокси для исходящих запросов к Telegram и OpenRouter.
# Нужен, если прямой доступ к api.telegram.org или OpenRouter заблокирован.
# Поддерживаются схемы http, https и socks5. Примеры:
#   PROXY_URL=http://user:pass@127.0.0.1:8080
#   PROXY_URL=socks5://127.0.0.1:1080
PROXY_URL=

# Сколько последних сообщений (user/assistant) держать как контекст диалога.
HISTORY_LIMIT=20

# Таймаут одного запроса к OpenRouter (формат Go duration: 60s, 90s, 2m).
REQUEST_TIMEOUT=60s

# Уровень логирования: debug | info | warn | error
LOG_LEVEL=info
